@unpublished{ku2026coverage,
  bibtex_show = {true},
  abbr        = {JMP},
  title       = {Coverage Substitution After Job Loss: How the ACA Altered Post-Displacement Insurance Trajectories},
  author      = {Ku, Sing-Hao},
  year        = {2026},
  month       = {5},
  note        = {M.A. Thesis, New York University (Advisor: Prof. Gustavo Pereira) — Highest Distinction in Cohort},
  abstract    = {Did the Affordable Care Act soften the post-displacement coverage shock that follows from the U.S. employer-tied insurance system? The 2014 introduction of community-rated Marketplace plans and the Medicaid expansion gave separated workers non-employer alternatives that the pre-ACA non-group market did not offer, and this paper measures whether those alternatives changed what happens to insurance coverage and out-of-pocket premium burden when workers lose their jobs involuntarily. Using the Medical Expenditure Panel Survey 2004-2018 and a matched event-study design adapted from Schaller and Zerpa (2026), I estimate era-specific displacement effects on a pre-ACA cohort and a post-ACA cohort and compare them. Post-ACA workers lose meaningfully less coverage than their pre-ACA counterparts: the ACA absorbs roughly one-quarter of the two-month post-displacement coverage loss, with the gains concentrated in the income bands the subsidy and expansion thresholds were designed to reach. The cost story has two parts that move in opposite directions: more workers end up on a plan requiring a premium, but among those who pay any premium, the high-burden share (over 10% of household income) roughly doubles between eras. Marketplace coverage is real insurance, but it is not cheap insurance. A latent-class analysis on baseline job characteristics adds a third layer: coverage gains concentrate in a high-coverage Finance and Professional class, while three precarious-work classes show no coverage gains, with what gains there are operating through the public-insurance margin rather than through Marketplace substitution.},
  pdf         = {Ku_Coverage_Substitution_ACA.pdf},
  selected    = {true}
}

@unpublished{ku2025medicaid,
  bibtex_show = {true},
  title       = {Medicaid Expansion and Out-of-Pocket Costs: Causal Evidence from Double Machine Learning},
  author      = {Ku, Sing-Hao},
  year        = {2025},
  month       = {5},
  note        = {Term paper, "Machine Learning for Economics," New York University},
  abstract    = {This study investigates the causal relationship between insurance coverage resulting from the ACA Medicaid expansion and medical out-of-pocket (MOOP) expenses, using a partial-linear instrumental-variables estimator with Double/Debiased Machine Learning (PLIV-DML, Chernozhukov et al., 2018) that lets flexible learners (Random Forest, LASSO, XGBoost) model high-dimensional controls while preserving valid inference. The empirical strategy exploits quasi-experimental variation between Medicaid-expansion and non-expansion states across low- and mid-FPL income subgroups (CPS ASEC, 2011-2017, approximately 786,000 observations). Two of the three learners point to meaningful cost savings and no learner finds a statistically significant increase in MOOP: Random Forest estimates gaining insurance reduces annual MOOP by roughly \$3,650 for mid-FPL adults and \$1,250 for low-FPL adults, with LASSO corroborating a sizable reduction (about \$7,300) in the mid-FPL group. The evidence is strongest and most precisely estimated for adults between 100% and 138% of the federal poverty line, reinforcing the broader case that public insurance expansions provide meaningful financial protection for low-income populations.},
  pdf         = {Ku_Medicaid_DML.pdf},
  selected    = {true}
}

@unpublished{ku2025nudging,
  bibtex_show = {true},
  title       = {Nudging in Public Policy: A Review of Empirical Studies},
  author      = {Ku, Sing-Hao},
  year        = {2025},
  month       = {5},
  note        = {Term paper, "Irrationality and Behavioral Economics," New York University},
  abstract    = {Reviews the theory of libertarian paternalism and nudging (Thaler & Sunstein), then evaluates two empirical papers testing when nudges outperform or underperform traditional price instruments: List et al. (2023) on nudges vs. taxes/subsidies across cigarette, vaccine, and electricity markets, and Handel (2011) on how reducing switching costs can worsen adverse selection in health insurance. Concludes with a discussion of "nudge plus," "budge," and "boost" as extensions to the classic nudge framework.},
  pdf         = {Ku_Nudging_Review.pdf},
  selected    = {true}
}
