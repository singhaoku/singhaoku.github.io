@unpublished{ku2026coverage,
  bibtex_show = {true},
  abbr        = {JMP},
  title       = {Coverage Substitution After Job Loss: How the ACA Altered Post-Displacement Insurance Trajectories},
  author      = {Ku, Sing-Hao},
  year        = {2026},
  month       = {5},
  note        = {M.A. Thesis, New York University (Advisor: Prof. Gustavo Pereira) — Highest Distinction in Cohort},
  abstract    = {Designed and executed a propensity-score-matched event-study difference-in-differences on a person-month panel of 5.9 million observations (MEPS 2004-2018), with a two-part hurdle decomposition of premium burden and latent class analysis of pre-displacement job profiles. Found the ACA absorbed roughly one-quarter of the two-month coverage loss and one-third of the four-month loss, with gains concentrated in a high-coverage Finance and Professional class while three precarious-work classes showed essentially no gains.},
  pdf         = {Ku_Coverage_Substitution_ACA.pdf},
  selected    = {true}
}

@unpublished{ku2025medicaid,
  bibtex_show = {true},
  title       = {Medicaid Expansion and Out-of-Pocket Costs: Causal Evidence from Double Machine Learning},
  author      = {Ku, Sing-Hao},
  year        = {2025},
  month       = {5},
  note        = {Term paper, "Machine Learning for Economics," New York University},
  abstract    = {Uses a Double/Debiased Machine Learning instrumental-variables estimator (Chernozhukov et al., 2018) with Random Forest, LASSO, and XGBoost to estimate the causal effect of ACA Medicaid expansion on medical out-of-pocket spending, exploiting quasi-experimental variation between expansion and non-expansion states across low- and mid-FPL income subgroups (CPS ASEC, 2011-2017, ~786,000 observations).},
  pdf         = {Ku_Medicaid_DML.pdf},
  selected    = {true}
}

@unpublished{ku2025nudging,
  bibtex_show = {true},
  title       = {Nudging in Public Policy: A Review of Empirical Studies},
  author      = {Ku, Sing-Hao},
  year        = {2025},
  month       = {5},
  note        = {Literature review, New York University (Advisor: Prof. Mario Rizzo)},
  abstract    = {Reviews the theory of libertarian paternalism and nudging (Thaler & Sunstein), then evaluates two empirical papers testing when nudges outperform or underperform traditional price instruments: List et al. (2023) on nudges vs. taxes/subsidies across cigarette, vaccine, and electricity markets, and Handel (2011) on how reducing switching costs can worsen adverse selection in health insurance. Concludes with a discussion of "nudge plus," "budge," and "boost" as extensions to the classic nudge framework.},
